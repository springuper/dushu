# 环境变量配置示例
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# ============================================
# LLM API 配置（选择其一或两者都配置）
# ============================================

# Google Gemini API（推荐）
# 获取地址：https://aistudio.google.com/apikey
# 支持 GEMINI_API_KEY 或 GOOGLE_API_KEY
GEMINI_API_KEY=your-gemini-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# Gemini 模型选择（可选，默认：gemini-1.5-flash）
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_MODEL=gemini-1.5-pro

# OpenAI API（可选）
# 获取地址：https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# OpenAI 模型选择（可选，默认：gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini

# OpenAI 自定义 API 地址（可选，用于兼容 OpenAI 的 API）
# OPENAI_BASE_URL=https://api.openai.com/v1

# LLM 请求超时（毫秒，可选，默认 300000 即 5 分钟）
# LLM_TIMEOUT_MS=300000

# ============================================
# 后端配置
# ============================================

# 数据库连接（必填）
# 本地开发
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dushu?schema=public
# Supabase 部署：使用 Session pool（端口 5432），一个连接串即可，无需 directUrl
# 从 Supabase Dashboard → Settings → Database → Connection string 获取
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# 代理（可选，国内访问 OpenAI 需要，如 Clash 默认 http://127.0.0.1:7890）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 服务器端口（可选，默认 3001）
# PORT=3001

# Session 密钥（生产环境必须修改）
# SESSION_SECRET=your-secret-key-here

# 前端 URL（CORS 白名单，生产环境前后端同源时可省略）
# 同源部署（后端 serve 前端）时可不配置；若前后端分离则需配置
# FRONTEND_URL=https://dushu.fly.dev
